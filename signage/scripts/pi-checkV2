#!/bin/bash

LOG_DIR="/home/vers/signage/logs"
DATE_ONLY=$(date '+%Y-%m-%d')
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
LOG_FILE="$LOG_DIR/health_report_${DATE_ONLY}.log"

health() {
    echo "============================================================"
    echo "                  RASPBERRY PI HEALTH REPORT                "
    echo "============================================================"
    echo "Generated on: $TIMESTAMP"
    echo

    echo "===================== SYSTEM INFORMATION ==================="
    echo "Hostname           : $(hostname)"
    echo "Kernel Version     : $(uname -r)"
    echo "OS                 : $(grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '"')"
    echo "Architecture       : $(uname -m)"
    echo "Uptime             : $(uptime -p)"
    echo "Last Boot          : $(who -b | awk '{print $3, $4}')"
    echo

    echo "======================== CPU STATUS ========================"
    CPU_LOAD=$(top -bn1 | grep "Cpu(s)" | awk '{print $2 + $4}')
    echo "CPU Load           : ${CPU_LOAD}%"
    if command -v nproc >/dev/null 2>&1; then
        echo "CPU Cores          : $(nproc)"
    fi
    if command -v vcgencmd >/dev/null 2>&1; then
        echo "CPU Temperature    : $(vcgencmd measure_temp | cut -d= -f2)"
        echo "CPU Throttled Info : $(vcgencmd get_throttled 2>/dev/null | cut -d= -f2)"
    else
        echo "CPU Temperature    : vcgencmd not available"
    fi
    echo

    echo "======================= MEMORY STATUS ======================"
    free -h
    echo
    MEM_PERCENT=$(free | awk '/Mem:/ {printf "%.2f", $3/$2 * 100}')
    echo "Memory Usage       : ${MEM_PERCENT}%"
    echo

    echo "======================== DISK STATUS ======================="
    df -h /
    echo
    ROOT_USAGE=$(df -h / | awk 'NR==2 {print $5}')
    echo "Root Partition Use : $ROOT_USAGE"
    echo

    echo "======================= NETWORK STATUS ====================="
    if ip link show wlan0 >/dev/null 2>&1; then
        IFACE="wlan0"
    elif ip link show eth0 >/dev/null 2>&1; then
        IFACE="eth0"
    else
        IFACE=""
    fi

    if [ -n "$IFACE" ]; then
        echo "Active Interface   : $IFACE"
        IP_ADDR=$(ip -4 addr show "$IFACE" | awk '/inet / {print $2}' | cut -d/ -f1)
        MAC_ADDR=$(cat /sys/class/net/"$IFACE"/address 2>/dev/null)
        RX=$(cat /sys/class/net/"$IFACE"/statistics/rx_bytes 2>/dev/null)
        TX=$(cat /sys/class/net/"$IFACE"/statistics/tx_bytes 2>/dev/null)
        STATE=$(cat /sys/class/net/"$IFACE"/operstate 2>/dev/null)

        echo "IP Address         : ${IP_ADDR:-Unavailable}"
        echo "MAC Address        : ${MAC_ADDR:-Unavailable}"
        echo "Interface State    : ${STATE:-Unavailable}"
        echo "Received Bytes     : ${RX:-Unavailable}"
        echo "Transmitted Bytes  : ${TX:-Unavailable}"

        echo
        echo "Ping Test (8.8.8.8):"
        ping -c 2 -W 2 8.8.8.8 >/dev/null 2>&1
        if [ $? -eq 0 ]; then
            echo "Internet Status    : Reachable"
        else
            echo "Internet Status    : Unreachable"
        fi
    else
        echo "No network interface found"
    fi
    echo

    echo "======================= STORAGE DETAIL ====================="
    echo "Mounted Filesystems:"
    df -h
    echo

    echo "======================= TOP PROCESSES ======================"
    echo "Top 5 CPU-consuming processes:"
    ps -eo pid,ppid,cmd,%mem,%cpu --sort=-%cpu | head -n 6
    echo
    echo "Top 5 Memory-consuming processes:"
    ps -eo pid,ppid,cmd,%mem,%cpu --sort=-%mem | head -n 6
    echo

    echo "======================= SERVICE STATUS ====================="
    for svc in ssh cron networking; do
        if systemctl list-unit-files | grep -q "^${svc}\.service"; then
            echo "$svc Service       : $(systemctl is-active "$svc" 2>/dev/null)"
        fi
    done
    echo

    echo "======================== JOURNAL ERRORS ===================="
    echo "Recent system errors (last 10):"
    journalctl -p 3 -n 10 --no-pager 2>/dev/null || echo "journalctl not available or no recent errors"
    echo

    echo "======================== REPORT END ========================"
    echo
    echo
}

mkdir -p "$LOG_DIR"
health >> "$LOG_FILE" 2>&1